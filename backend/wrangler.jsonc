{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "tracker",
  "compatibility_date": "2026-03-05",
  "pages_build_output_dir": "../dist",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "tracker-db",
      "database_id": "local-only-placeholder"
    }
  ]
}
