{
  "name": "tracker",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --ssr backend/src/app.ts --outDir dist",
    "db:local:setup": "node scripts/setup-local-db.cjs",
    "local:start": "npm run db:local:setup && npm run build && npm run preview -- --persist-to=./meu_banco",
    "preview": "wrangler pages dev ./dist --local --d1 DB",
    "deploy": "npm run build && wrangler pages deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-cloudflare-pages": "^0.4.3",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
